# ============================================
# VARIABLES DE ENTORNO - BACKEND E-COMMERCE (.env)
# ============================================
# Este archivo contiene TODAS las configuraciones sensibles y variables del proyecto.
# Se carga al inicio del servidor con: require('dotenv').config() en server.js
# Las variables se acceden como: process.env.NOMBRE_VARIABLE
#
# IMPORTANTE:
#   - Este archivo NO se sube a GitHub (debe estar en .gitignore)
#   - Cada desarrollador tiene su propia copia con sus credenciales
#   - En producción se configuran directamente en el servidor (no en archivo)

# ----------------
# SERVIDOR
# ----------------
# PORT → Puerto donde escucha el servidor Express
# El servidor arranca en: http://localhost:5000
# Se usa en server.js: const PORT = process.env.PORT || 5000
PORT=5000

# NODE_ENV → Modo de ejecución del servidor
# 'development' → activa logging, alter de tablas, stack trace en errores
# 'production'  → desactiva logging, protege estructura de BD, oculta errores internos
# Se usa en server.js para activar/desactivar funcionalidades según el entorno
NODE_ENV=development

# ----------------
# BASE DE DATOS MYSQL
# ----------------
# Estas variables se usan en config/database.js para la conexión con Sequelize
# Requiere que XAMPP (MySQL) esté corriendo en el puerto indicado

# DB_HOST → Dirección del servidor MySQL (localhost = misma máquina)
DB_HOST=localhost

# DB_PORT → Puerto de MySQL en XAMPP (por defecto es 3306)
DB_PORT=3306

# DB_NAME → Nombre de la base de datos que usa el sistema
# Se crea automáticamente en config/createDatabase.js si no existe
DB_NAME=ecommerce_db

# DB_USER → Usuario de MySQL para conectarse
# 'root' es el usuario por defecto de XAMPP (tiene todos los permisos)
DB_USER=root

# DB_PASSWORD → Contraseña del usuario MySQL
# En XAMPP el usuario root no tiene contraseña por defecto (vacío)
# En producción DEBE tener una contraseña segura
DB_PASSWORD=

# ----------------
# JWT (JSON WEB TOKENS)
# ----------------
# JWT se usa para la autenticación de usuarios (login/register)
# Estas variables se usan en config/jwt.js

# JWT_SECRET → Clave secreta para firmar y verificar los tokens JWT
# Es como una "contraseña" que solo el servidor conoce
# Si alguien obtiene esta clave, podría falsificar tokens (NUNCA compartir)
# En producción debe ser una cadena aleatoria larga y compleja
JWT_SECRET=mi_clave_secreta_super_segura_2026

# JWT_EXPIRES_IN → Tiempo de expiración del token
# '24h' = 24 horas → después de 24h el usuario debe hacer login de nuevo
# Opciones: '1h' (1 hora), '7d' (7 días), '30m' (30 minutos)
JWT_EXPIRES_IN=24h

# ----------------
# CONFIGURACIÓN DE ARCHIVOS (MULTER)
# ----------------
# Multer maneja la subida de imágenes de productos
# Estas variables se usan en config/multer.js

# UPLOAD_PATH → Carpeta donde se guardan las imágenes subidas
# Relativo a la raíz del backend → ./uploads = backend/uploads/
# Las imágenes son accesibles en: http://localhost:5000/uploads/nombre-imagen.jpg
UPLOAD_PATH=./uploads

# MAX_FILE_SIZE → Tamaño máximo permitido para archivos subidos (en bytes)
# 5242880 bytes = 5 MB (5 * 1024 * 1024)
# Si el archivo es más grande, Multer rechaza la petición con error
MAX_FILE_SIZE=5242880

# ----------------
# CORS (Cross-Origin Resource Sharing)
# ----------------
# CORS controla qué dominios pueden hacer peticiones al backend
# Se usa en server.js en la configuración de cors()

# FRONTEND_URL → URL del frontend React que tiene permiso para hacer peticiones
# En desarrollo: React corre en http://localhost:3000
# En producción: sería la URL del dominio (ej: https://mi-tienda.com)
FRONTEND_URL=http://localhost:3000
